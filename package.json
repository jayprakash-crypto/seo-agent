{
  "name": "seo-agent",
  "version": "1.0.0",
  "description": "Autonomous SEO platform — 18 MCP servers + orchestrators + dashboard",
  "private": true,
  "type": "module",
  "workspaces": [
    "src/mcp-servers/*",
    "src/mcp-template",
    "src/dashboard"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
