# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-32-char-random-string

# Single-operator auth
DASHBOARD_PASSWORD=your-strong-password-here

# TOTP 2FA — generate with GET /api/auth/setup-totp?token=<SETUP_TOKEN>
TOTP_SECRET=
SETUP_TOKEN=one-time-setup-token

# Approvals API (Express server, server-side only)
APPROVALS_API_URL=http://localhost:3002

# WebSocket server (client-side — use Railway URL in production)
NEXT_PUBLIC_WS_URL=http://localhost:3002

# Approvals API (client-side direct fetch — can match APPROVALS_API_URL in dev)
NEXT_PUBLIC_API_URL=http://localhost:3002

# MySQL (Prisma)
DATABASE_URL=mysql://user:password@localhost:3306/seo_agent

# Google Search Console credentials (per site)
GSC_OAUTH_SITE_1={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
