// Prisma schema — SEO Agent Operator Dashboard

generator client {
  provider = "prisma-client-js"
}

// ── MySQL (commented out) ──────────────────────────────────────────────
// datasource db {
//   provider = "mysql"
//   url      = env("DATABASE_URL")
// }
// MySQL type notes:
//   - Json       → JSON column (no binary indexing)
//   - String @id → VARCHAR(191) by default
//   - DateTime   → DATETIME(3)
//   - detail String → VARCHAR(191) — TEXT requires @db.Text annotation

// ── PostgreSQL ─────────────────────────────────────────────────────────
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// PostgreSQL type notes:
//   - Json       → JSONB (binary JSON, indexable)
//   - String @id → TEXT
//   - DateTime   → TIMESTAMP(3) — add @db.Timestamptz for timezone-aware
//   - detail String @db.Text → TEXT (unlimited length)

model Approval {
  id            String    @id @default(cuid())
  site_id       Int
  module        String    @db.VarChar(64)   // 'gbp-manager', 'review-responder', etc.
  type          String    @db.VarChar(64)   // 'gbp_post', 'review_response', 'meta_rewrite'
  priority      Int                         // 1=critical, 2=high, 3=medium
  title         String    @db.VarChar(255)
  content       Json                        // JSONB in PostgreSQL — full draft content
  preview_url   String?   @db.VarChar(512)
  status        String    @default("pending") @db.VarChar(16) // pending | approved | rejected | deferred
  created_at    DateTime  @default(now()) @db.Timestamptz
  actioned_at   DateTime? @db.Timestamptz
  actioned_by   String?   @db.VarChar(64)
  reject_reason String?   @db.VarChar(255)

  action_logs ActionLog[]

  @@index([status, priority])
  @@index([site_id])
}

model Alert {
  id          String    @id @default(cuid())
  site_id     Int
  module      String    @db.VarChar(64)
  severity    String    @db.VarChar(16)  // 'critical' | 'warning' | 'info'
  title       String    @db.VarChar(255)
  detail      String    @db.Text         // unlimited length — TEXT in PostgreSQL
  status      String    @default("open") @db.VarChar(16) // open | acknowledged | resolved
  created_at  DateTime  @default(now()) @db.Timestamptz
  resolved_at DateTime? @db.Timestamptz

  @@index([status, severity])
  @@index([site_id])
}

model ActionLog {
  id          String    @id @default(cuid())
  approval_id String?
  action      String    @db.VarChar(32)  // 'approved' | 'rejected' | 'edited' | 'deferred'
  module      String    @db.VarChar(64)
  time_spent  Int                        // seconds spent reviewing
  created_at  DateTime  @default(now()) @db.Timestamptz

  approval    Approval? @relation(fields: [approval_id], references: [id])
}

model WeeklyDigest {
  id          String   @id @default(cuid())
  site_id     Int
  week_start  DateTime @db.Timestamptz
  content     Json                       // JSONB — full Claude digest output
  top_actions Json                       // JSONB — array of top 3 actions
  created_at  DateTime @default(now()) @db.Timestamptz

  @@index([site_id, week_start])
}
