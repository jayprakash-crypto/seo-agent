# Anthropic
ANTHROPIC_API_KEY=

# Google — one set per site (replace N with site_id: 1, 2, 3 etc.)
GSC_OAUTH_SITE_1= # Path to service account JSON or JSON string
GBP_OAUTH_SITE_1= # GBP OAuth token JSON
ADS_ACCOUNT_SITE_1= # Google Ads account ID

# SEO APIs
SEMRUSH_KEY=
AHREFS_KEY=
SERPAPI_KEY=
BING_WEBMASTER_KEY=

# CMS — one per site
CMS_API_URL_SITE_1= # e.g. https://lifecircle.in/wp-json/wp/v2
CMS_API_KEY_SITE_1= # WordPress application password

# Notifications
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Google Sheets
SHEETS_ID= # The spreadsheet ID from the URL

# Database (Dashboard)
DATABASE_URL= # PostgreSQL connection string
